# Copy to .env and fill in. Variables are read at startup via pydantic-settings.

# --- Azure OpenAI (required) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names you created in the Azure portal.
# These replace model names like "gpt-4o-mini" — Azure routes by deployment.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-4o-mini

# Embedding deployment (e.g. text-embedding-3-small or text-embedding-ada-002).
# Used for both index build and per-query retrieval.
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
